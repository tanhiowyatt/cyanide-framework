name: ""
type: directory
perm: drwxr-xr-x
owner: root
group: root
children:
  - name: etc
    type: directory
    perm: drwxr-xr-x
    children:
      - name: passwd
        type: file
        perm: "-rw-r--r--"
        content: |
          root:x:0:0:root:/root:/bin/bash
          admin:x:1000:1000:Admin User:/home/admin:/bin/bash
      - name: shadow
        type: file
        perm: "-rw-------"
        owner: root
        content: |
          root:$6$salt$hashedhash:18000:0:99999:7:::
          admin:$6$salt$hashedhash:18000:0:99999:7:::

  - name: home
    type: directory
    perm: drwxr-xr-x
    children:
      - name: admin
        type: directory
        perm: drwxr-xr-x
        owner: admin
        group: admin
        children:
          - name: .bash_history
            type: file
            perm: "-rw-------"
            owner: admin
            content: |
              ls -la
              cat /etc/passwd
              mysql -u root -pMyPassword123
              ssh production-server
          - name: notes.txt
            type: file
            perm: "-rw-r--r--"
            content: |
              Production server: 10.0.0.100
              SSH key in ~/.ssh/id_rsa
              Remember to backup database!

  - name: var
    type: directory
    perm: drwxr-xr-x
    children:
      - name: www
        type: directory
        perm: drwxr-xr-x
        children:
          - name: html
            type: directory
            perm: drwxr-xr-x
            children:
              - name: index.html
                type: file
                perm: "-rw-r--r--"
                content: |
                  <html>
                  <body>
                  <h1>Welcome to Production Server</h1>
                  </body>
                  </html>

  - name: root
    type: directory
    perm: drwx------
    owner: root
    children:
      - name: .ssh
        type: directory
        perm: drwx------
        children:
          - name: authorized_keys
            type: file
            perm: "-rw-------"
            content: |
              ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABgQC... admin@laptop
