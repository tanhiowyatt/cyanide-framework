[honeypot]
# Hostname reported by the honeypot
# Example: server01, db-prod, main-gateway
# Values: String (any valid hostname)
hostname = server01

# Path to store logs
# Values: String (valid file path)
log_path = var/log/cyanide

# Path to store data (e.g. quarantine)
# Values: String (valid file path)
data_path = var/lib/cyanide

# Path to the YAML filesystem configuration
# You can edit this file manually to add honey files
fs_yaml = data/cyanide/fs.yaml

fs_yaml = data/cyanide/fs.yaml


[server]
# IP address to bind to (0.0.0.0 for all interfaces)
# Values: String (valid IP address)
host = 0.0.0.0

# OS Consistency Profile: determines filesystem structure and command output styles
# Options: 
#   - ubuntu_22_04 (Mimics Ubuntu 22.04 LTS)
#   - debian_11 (Mimics Debian 11 Bullseye)
#   - centos_7 (Mimics CentOS 7)
#   - custom (Uses metadata from [custom_profile] and fs.custom.yaml)
#   - random (Selects a profile randomly on startup)
os_profile = random

# Example Custom Profile (Optional)
# Used only if os_profile = custom
# [custom_profile]
# name = My Custom Linux
# ssh_banner = SSH-2.0-OpenSSH_9.0
# uname_r = 6.1.0-custom
# uname_a = Linux my-server 6.1.0-custom #1 SMP PREEMPT_DYNAMIC x86_64 GNU/Linux
# etc_issue = My Custom Distro \n \l\n\n
# proc_version = Linux version 6.1.0-custom (user@build-machine) (gcc 12) #1 SMP

# Maximum total concurrent sessions allowed
# Values: Integer (e.g. 100)
max_sessions = 100

# Maximum concurrent sessions per IP address
# Values: Integer (e.g. 5)
max_sessions_per_ip = 5

# Session timeout in seconds (force disconnect if idle/connected too long)
# Values: Integer (seconds)
session_timeout = 300

# Max size of quarantine folder in MB before rejecting new file uploads
# Values: Integer (MB)
quarantine_max_size_mb = 500


[users]
# User credentials definition
# Format: username = password
# Values: String = String
root = admin
admin = admin
user = 123456


[metrics]
# Enable Prometheus metrics server
# Values: true | false
enabled = true

# Port for metrics server (e.g., localhost:9090/metrics and /stats)
# Values: Integer (valid port 1-65535)
port = 9090


[ml]
# Enable Machine Learning anomaly detection
# Analyzes commands against known patterns and knowledge base
# Values: true | false
enabled = true

# Port for ML metrics (shared with metrics server if same port)
# Values: Integer (valid port 1-65535)
metrics_port = 9090

# Path to ML log file where anomalies are recorded
# Values: String (valid file path)
ml_log = var/log/cyanide/cyanideML-log.json

# Path to the trained ML model file
# Values: String (valid file path)
model_path = ai_models/cyanideML/cyanideML.pkl

# Enable online learning (updating model with new data in real-time)
# Values: true | false
# Default: false (recommended for stability)
online_learning = false


[ssh]
# Enable SSH honeypot service
# Values: true | false
enabled = true

# Port to listen on
# Use 2222 if running as non-root user, or 22 if using port forwarding/root
# Values: Integer (valid port 1-65535)
listen_port = 2222

# Enable RSA key generation for host keys
# Values: true | false
rsa_keying = true

# SSH Version string to announce to clients
# Example: SSH-2.0-OpenSSH_8.2p1 Ubuntu-4ubuntu0.5
# Values: String
version = SSH-2.0-OpenSSH_8.2p1 Ubuntu-4ubuntu0.5

# Backend mode for SSH handling
# Options:
#   - emulated: Fully emulated python shell (safest, medium interaction)
#   - proxy: Forward traffic to a single target host (high interaction risk)
#   - pool: Forward traffic to a pool of target VMs (high interaction risk)
# backend_mode = emulated

# If backend_mode is 'proxy', specify target:
# target_host = 127.0.0.1
# target_port = 22222


[telnet]
# Enable Telnet honeypot service
# Values: true | false
enabled = true

# Port to listen on (e.g., 23 or 2223)
# Values: Integer (valid port 1-65535)
listen_port = 2223

# Backend mode for Telnet handling
# Options: emulated, proxy, pool
# backend_mode = emulated

# If backend_mode is 'proxy', specify target:
# target_host = 127.0.0.1
# target_port = 2323


[smtp]
# Enable SMTP proxy/honeypot for capturing emails/spam
# Values: true | false
enabled = true

# Port to listen on (e.g., 25 or 2525)
# Values: Integer (valid port 1-65535)
listen_port = 2525

# Target host to forward SMTP traffic to (e.g., a mock SMTP server like MailHog)
# Values: String (valid IP or hostname)
target_host = 127.0.0.1
# Values: Integer (valid port 1-65535)
target_port = 25255


[output]
# Log format configuration
# If true, logs are written in JSONL format for easy parsing
# Values: true | false
json_log = true


[cleanup]
# Enable automatic cleanup of old logs and quarantine files
# Values: true | false
enabled = true

# Cleanup interval in seconds (how often to check)
# Values: Integer (seconds)
interval = 3600

# Retention period in days (files older than this are deleted)
# Values: Integer (days)
retention_days = 7

# Comma-separated paths to performing cleanup in
# Values: String (comma-separated list of paths)
paths = var/log/cyanide,var/lib/cyanide


[virustotal]
# Enable VirusTotal scanning for uploaded files
# Values: true | false
enabled = true

# API Key for VirusTotal (Recommended to set in .env as VIRUSTOTAL_API_KEY)
# Values: String (API Key)
# api_key = 


[pool]
# VM Pool targets for 'pool' backend_mode
# Format: host:port,host:port
# Values: String (comma-separated host:port list)
# targets = 192.168.1.10:22,192.168.1.11:22
