# /etc/environment
# The environment.conf(5) man page documents the syntax of this file.
# Be careful: do not edit this file with a utility that changes
# the file encoding. Specifically, editors like kate or gedit might
# create a BOM (byte-order mark) at the beginning of the file.
LANG=en_US.UTF-8
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
