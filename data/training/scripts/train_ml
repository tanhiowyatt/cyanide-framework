#!/usr/bin/env python3
import sys
import argparse
import time
import json
from pathlib import Path
import glob

# Add project root to path
sys.path.append(str(Path(__file__).resolve().parent.parent / "src"))
# We need to ensure we can import from src/cyanide
# The user might run this from project root
sys.path.append(str(Path.cwd() / "src"))

from cyanide.core.config import load_config
from cyanide.ml.cyanideML.model import HoneypotFilter
from cyanide.ml.cyanideML.knowledge_base import KnowledgeBase

def log_generator(path):
    """Yields log entries from JSON files in path."""
    files = glob.glob(str(Path(path) / "**" / "cowrie.json*"), recursive=True)
    # print(f"[*] Found {len(files)} log files for training.")
    count = 0
    for fpath in files:
        try:
            with open(fpath, 'r') as f:
                for line in f:
                    try:
                        yield json.loads(line)
                        count += 1
                        if count % 10000 == 0:
                            print(f"    Processed {count} logs...", end='\r')
                    except json.JSONDecodeError:
                        continue
        except Exception as e:
            print(f"[!] Error reading {fpath}: {e}")
    # print(f"\n[*] Total logs yielded: {count}")

def train_anomaly_detector(force=False):
    """
    Train the ML model (Anomaly Detector)
    Logic: Checks if 7 days passed since last run OR force is True.
    """
    config = load_config()
    ml_conf = config.get("ml", {})
    
    # 0. Check Scheduling
    state_file = Path("var/lib/cyanide/ml_state.json")
    if state_file.exists() and not force:
        try:
            with open(state_file, 'r') as f:
                state = json.load(f)
            last_run = state.get("last_train_run", 0)
            # 7 days in seconds
            if time.time() - last_run < 7 * 24 * 3600:
                print("[*] Skipping model training (less than 7 days since last run). use --force to override.")
                return
        except Exception as e:
            print(f"[!] Error reading state file: {e}")

    # 1. Paths
    hacker_methods_path = ml_conf.get("training_data", {}).get("hacker_methods")
    model_path = Path(ml_conf.get("model_path"))
    
    print(f"[*] Training Anomaly Detector...")
    print(f"[*] Hacker Data: {hacker_methods_path}")
    print(f"[*] Model Goal:  {model_path}")

    # 2. Train Anomaly Detector
    print("\n--- Phase 1: Training Anomaly Detector ---")
    model = HoneypotFilter(online_learning=False) # Offline mode for training
    
    iterator = log_generator(hacker_methods_path)
    model.fit_offline(iterator)
    
    # Save Model
    model_path.parent.mkdir(parents=True, exist_ok=True)
    model.save(str(model_path))
    
    # Update State
    state_file.parent.mkdir(parents=True, exist_ok=True)
    with open(state_file, 'w') as f:
        json.dump({"last_train_run": time.time()}, f)
        
    print(f"\n[+] Anomaly Detector Training Complete.")

def build_kb():
    """
    Build/Update Knowledge Base (Manual Trigger).
    """
    config = load_config()
    ml_conf = config.get("ml", {})
    mitre_cve_path = ml_conf.get("training_data", {}).get("mitre_cve")
    model_path = Path(ml_conf.get("model_path"))
    
    print("\n--- Phase 2: Building Knowledge Base ---")
    print(f"[*] MITRE Data:  {mitre_cve_path}")
    
    kb = KnowledgeBase(Path(mitre_cve_path))
    kb.build()
    
    kb_path = model_path.parent / "knowledge_base.pkl"
    # Create directory just in case
    kb_path.parent.mkdir(parents=True, exist_ok=True)
    kb.save(str(kb_path))
    
    print(f"[*] Knowledge Base saved to {kb_path}")
    print("\n[+] Knowledge Base Build Complete.")

def main():
    parser = argparse.ArgumentParser(description="Cyanide ML Training Manager")
    parser.add_argument("--train-model", action="store_true", help="Train anomaly detector (auto 7-day check)")
    parser.add_argument("--build-kb", action="store_true", help="Build/Update Knowledge Base (manual)")
    parser.add_argument("--force", action="store_true", help="Force model training ignoring schedule")
    
    args = parser.parse_args()
    
    if not (args.train_model or args.build_kb):
        print("No action specified. Run with --train-model and/or --build-kb")
        parser.print_help()
        sys.exit(1)
        
    if args.train_model:
        train_anomaly_detector(args.force)
        
    if args.build_kb:
        build_kb()

if __name__ == "__main__":
    main()
