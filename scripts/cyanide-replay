#!/usr/bin/env python3
import sys
import os
import json
import re
from pathlib import Path

def convert_log(log_path):
    if not os.path.exists(log_path):
        print(f"Error: File {log_path} not found.")
        sys.exit(1)

    output_lines = []
    start_time = 0.0
    
    # 1. Header (Asciinema v2)
    header = {
        "version": 2,
        "width": 120, # Default, improved if we logged resize events
        "height": 40,
        "timestamp": 0,
        "env": {"SHELL": "/bin/bash", "TERM": "xterm-256color"}
    }
    
    with open(log_path, 'r', encoding='utf-8', errors='ignore') as f:
        lines = f.readlines()
        
    if not lines:
        return
        
    # Extract start time from first line
    # Format: Session 1234abcd started at 1709...
    first_line = lines[0]
    match = re.search(r'started at (\d+\.\d+)', first_line)
    if match:
        start_time = float(match.group(1))
        header["timestamp"] = int(start_time)
        
    print(json.dumps(header))
    
    # 2. Events
    # Format: 1709... [IN|OUT] 'data'
    # Asciinema expects relative time
    
    for line in lines[1:]:
        try:
            parts = line.split(" ", 2)
            if len(parts) < 3: continue
            
            ts_str = parts[0]
            direction = parts[1] # [IN] or [OUT]
            data_repr = parts[2]
            
            # We only care about OUT for playback usually, 
            # In asciinema, "o" is stdout, "i" is stdin. 
            # Replaying "i" might be redundant if "o" contains the echo.
            # usually for honeypots "OUT" shows what the attacker saw.
            
            if "[OUT]" not in direction:
                continue
                
            ts = float(ts_str)
            
            # Data is repr()'d in the log, so eval it safely or parse
            # Our logger did: enc_data = repr(data)
            # So data_repr is "'foo\nbar'" including quotes
            try:
                # ast.literal_eval is safer than eval
                import ast
                content = ast.literal_eval(data_repr.strip())
            except:
                content = data_repr
                
            rel_time = ts - start_time
            if rel_time < 0: rel_time = 0
            
            event = [round(rel_time, 6), "o", content]
            print(json.dumps(event))
            
        except Exception as e:
            # sys.stderr.write(f"Skipping line: {e}\n")
            pass

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: cyanide-replay <log_file>")
        print("Example: cyanide-replay var/log/cyanide/tty/1a2b3c4d.log > playback.cast")
        sys.exit(1)
        
    convert_log(sys.argv[1])
