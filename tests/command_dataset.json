{
    "Navigation": [
        {
            "command": "pwd",
            "expect": "/root"
        },
        {
            "command": "cd /tmp",
            "expect": ""
        },
        {
            "command": "pwd",
            "expect": "/tmp"
        },
        {
            "command": "cd /",
            "expect": ""
        },
        {
            "command": "cd ..",
            "expect": ""
        },
        {
            "command": "pwd",
            "expect": "/"
        },
        {
            "command": "cd ..",
            "expect": ""
        },
        {
            "command": "pwd",
            "expect": "/"
        }
    ],
    "File Operations": [
        {
            "command": "ls /",
            "expect": "bin"
        },
        {
            "command": "ls /bin",
            "expect": "bash"
        },
        {
            "command": "mkdir /tmp/test_dir",
            "expect": ""
        },
        {
            "command": "ls /tmp",
            "expect": "test_dir"
        },
        {
            "command": "touch /tmp/test_file.txt",
            "expect": ""
        },
        {
            "command": "ls /tmp",
            "expect": "test_file.txt"
        },
        {
            "command": "cat /etc/passwd",
            "expect": "root:x:0:0"
        },
        {
            "command": "cp /etc/passwd /tmp/passwd_backup",
            "expect": ""
        },
        {
            "command": "ls /tmp",
            "expect": "passwd_backup"
        },
        {
            "command": "mv /tmp/test_file.txt /tmp/moved_file.txt",
            "expect": ""
        },
        {
            "command": "ls /tmp",
            "expect": "moved_file.txt"
        },
        {
            "command": "rm /tmp/moved_file.txt",
            "expect": ""
        },
        {
            "command": "ls /tmp",
            "expect": [
                "!moved_file.txt"
            ]
        },
        {
            "command": "rmdir /tmp/test_dir",
            "expect": ""
        }
    ],
    "System Information": [
        {
            "command": "whoami",
            "expect": "root"
        },
        {
            "command": "id",
            "expect": "uid=0(root)"
        },
        {
            "command": "uname -a",
            "expect": "Linux"
        },
        {
            "command": "ps aux",
            "expect": "PID"
        },
        {
            "command": "who",
            "expect": "root"
        },
        {
            "command": "w",
            "expect": "USER"
        }
    ],
    "Shell Features": [
        {
            "command": "echo 'Hello World' > /tmp/hello.txt",
            "expect": ""
        },
        {
            "command": "cat /tmp/hello.txt",
            "expect": "Hello World"
        },
        {
            "command": "echo 'Line 2' >> /tmp/hello.txt",
            "expect": ""
        },
        {
            "command": "cat /tmp/hello.txt",
            "expect": [
                "Hello World",
                "Line 2"
            ]
        },
        {
            "command": "cat /etc/passwd | grep root",
            "expect": "root:x:0:0"
        },
        {
            "command": "ls /bin | head -n 5",
            "expect": ""
        },
        {
            "command": "ls /nonexistent && echo 'Success' || echo 'Failure'",
            "expect": "Failure"
        },
        {
            "command": "ls /bin && echo 'ChainWork'",
            "expect": "ChainWork"
        }
    ],
    "Advanced": [
        {
            "command": "sudo whoami",
            "expect": "root"
        },
        {
            "command": "sudo -u admin whoami",
            "expect": "admin"
        },
        {
            "command": "grep -i 'ubuntu' /etc/issue",
            "expect": "Ubuntu"
        },
        {
            "command": "ping -c 3 8.8.8.8",
            "expect": "PING 8.8.8.8"
        },
        {
            "command": "curl -I http://google.com",
            "expect": "HTTP/1.1"
        }
    ]
}